# ============================================================================
# Unified Agent Trading - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env file to version control

# ============================================================================
# LLM Configuration (Dual-Model Routing)
# ============================================================================

# Reasoning Model: Used for deep analysis, writing, and logic
# Provider options: openai, ollama, deepseek, dashscope, openrouter, zai, anthropic, fireworks
REASONING_MODEL_PROVIDER=openrouter
REASONING_MODEL_ID=gpt-4o
REASONING_MODEL_HOST=

# Tool Model: Used for tool calling, searching, and data fetching
TOOL_MODEL_PROVIDER=ollama
TOOL_MODEL_ID=qwen3:latest
TOOL_MODEL_HOST=http://127.0.0.1:11434

# Legacy/Default Configuration (Fallback)
LLM_PROVIDER=openrouter
LLM_MODEL=gpt-4o
LLM_HOST=

# ============================================================================
# Official LLM Provider API Keys
# ============================================================================

# OpenAI - https://platform.openai.com/
OPENAI_API_KEY=

# Anthropic - https://anthropic.com/
ANTHROPIC_API_KEY=

# DeepSeek - https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Qwen (Alibaba) - https://www.alibabacloud.com/help/en/model-studio/what-is-qwen-llm
QWEN_API_KEY=

# Zhipu AI - https://open.bigmodel.cn/
ZHIPU_API_KEY=

# ============================================================================
# Third-party LLM Proxy Services
# ============================================================================

# Yi-Zhan - https://vip.yi-zhan.top/
YIZHAN_API_KEY=

# AiHubMix - https://aihubmix.com/
AIHUBMIX_API_KEY=

# Fireworks AI - https://fireworks.ai/
FIREWORKS_API_KEY=

# OpenRouter - https://openrouter.ai/
OPENROUTER_API_KEY=

# ZAI - https://zai-api.top/
ZAI_KEY_API=

# UST Provider (HKUST-GZ AI)
UST_KEY_API=
UST_URL=

# DashScope (Alibaba)
DASHSCOPE_API_KEY=

# ============================================================================
# Financial Data Provider API Keys
# ============================================================================

# TuShare - Chinese A-share market data
# Sign up at: https://tushare.pro/register
TUSHARE_API_KEY=

# Alpha Vantage - US and international market data
# Sign up at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Financial Modeling Prep (FMP) - US/UK/Canada market data
# Sign up at: https://financialmodelingprep.com/
FMP_API_KEY=

# SEC EDGAR - free 13F institutional and Form 4 insider filings (no key needed)
# SEC requires a User-Agent with contact info: "AppName/1.0 (email@example.com)"
SEC_EDGAR_USER_AGENT=
# Minimum seconds between SEC requests (fair-access limit is 10 req/s)
SEC_EDGAR_MIN_INTERVAL=0.15

# ApeWisdom - free Reddit retail-sentiment mention rankings (no key needed)
# Minimum seconds between ApeWisdom requests
APEWISDOM_MIN_INTERVAL=1.0

# Alt-data snapshots: date-partitioned capture + deterministic replay.
# Modes: off (default) | refresh (fetch live, save daily snapshot) |
#        prefer_local (serve today's snapshot when present) |
#        local_only (replay from snapshots, never hit the network)
# Recommended for daily live/paper runs: refresh (accumulates history).
APEWISDOM_SNAPSHOT_MODE=off
APEWISDOM_SNAPSHOT_DIR=data/cache/apewisdom
SEC_EDGAR_SNAPSHOT_MODE=off
SEC_EDGAR_SNAPSHOT_DIR=data/cache/sec_edgar
# How many days back local_only replay may reach for the nearest snapshot
APEWISDOM_SNAPSHOT_LOOKBACK_DAYS=7
SEC_EDGAR_SNAPSHOT_LOOKBACK_DAYS=7

# ============================================================================
# Search and Extraction Services
# ============================================================================

# Jina AI - for Search (s.jina.ai) and Reader (r.jina.ai)
# Optional but recommended for better web extraction
JINA_API_KEY=

# Tavily - AI-optimized web search (optional)
TAVILY_API_KEY=
# Tavily request tuning (faster fail + lightweight retry)
TAVILY_CONNECT_TIMEOUT_SECONDS=3
TAVILY_READ_TIMEOUT_SECONDS=8
TAVILY_MAX_RETRIES=1
TAVILY_RETRY_BACKOFF_SECONDS=0.4
TAVILY_NEWS_CACHE_ENABLED=true
TAVILY_NEWS_CACHE_MAX_ENTRIES=1024
# Snapshot mode: prefer_local | local_only | refresh | off
TAVILY_NEWS_SNAPSHOT_MODE=prefer_local
# Persistent snapshot directory (used by backtest reuse)
TAVILY_NEWS_SNAPSHOT_DIR=data/cache/tavily_news

# ============================================================================
# Database Configuration
# ============================================================================

# Local SQLite database path (relative to project root)
DB_PATH=data/unified_trading.db

# Supabase cloud database (optional)
# Sign up at: https://supabase.com/
SUPABASE_URL=
SUPABASE_KEY=

# ============================================================================
# DeepEar Configuration
# ============================================================================

# Sentiment Analysis Settings
SENTIMENT_MODE=auto
BERT_SENTIMENT_MODEL=uer/roberta-base-finetuned-chinanews-chinese

# Search and Extraction Settings
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
SEARCH_CACHE_TTL=3600

# ISQ Template
ISQ_TEMPLATE=default_isq_v1

# Skill Server Settings
DEEPEAR_SERVER_PORT=8001
DEEPEAR_INSTANCES=1

# ============================================================================
# DeepFund Configuration
# ============================================================================

# Investment Personality
# Options: conservative, aggressive, passive, balanced
DEEPFUND_PERSONALITY=balanced

# Position Management
DEEPFUND_MAX_POSITION_RATIO=0.33
DEEPFUND_CASHFLOW=100000

# Trading Frequency
# Options: low, medium, high
DEEPFUND_TRADING_FREQUENCY=medium

# Company news data provider for DeepFund/backtest
# Options: default, tavily, tavily_strict, akshare, akshare_strict, auto
# akshare=use AKShare only and return [] on miss/error; akshare_strict=raise on error
COMPANY_NEWS_PROVIDER=default

# AKShare company news tuning
AKSHARE_NEWS_SNAPSHOT_MODE=prefer_local
AKSHARE_NEWS_SNAPSHOT_DIR=data/cache/akshare_news
AKSHARE_NEWS_LOOKBACK_DAYS=5
AKSHARE_MAX_RETRIES=1
AKSHARE_RETRY_BACKOFF_SECONDS=0.3
AKSHARE_NEWS_CACHE_ENABLED=true
AKSHARE_NEWS_CACHE_MAX_ENTRIES=1024
AKSHARE_NOTICE_ENABLED=true
AKSHARE_NOTICE_SYMBOL=全部
AKSHARE_NOTICE_HIGH_SIGNAL_ONLY=true
AKSHARE_NOTICE_CACHE_ENABLED=true
AKSHARE_NOTICE_CACHE_MAX_ENTRIES=400

# ============================================================================
# Logging Configuration
# ============================================================================

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log File Path
LOG_FILE=logs/unified_trading.log

# ============================================================================
# Report Configuration
# ============================================================================

# Reports Output Directory
REPORTS_OUTPUT_DIR=reports

# Report Format: markdown, html, both
REPORT_FORMAT=markdown

# Include Charts in Reports
REPORT_INCLUDE_CHARTS=true

# ============================================================================
# Advanced Settings
# ============================================================================

# Checkpoint/Resume Support
CHECKPOINTING_ENABLED=true
CHECKPOINTING_DIR=.checkpoints

# Concurrency Settings
MAX_WORKERS=4

# Cache Settings
CACHE_ENABLED=true
CACHE_DIR=.cache
CACHE_TTL=3600
